# Required: free key from https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_key_here

# Optional: overrides the default model. The default (openai/gpt-oss-120b) is
# current and free. If Groq deprecates it, set a current free model here.
# GROQ_MODEL=openai/gpt-oss-120b

# Optional: if set, web_search uses Tavily instead of keyless DuckDuckGo.
# TAVILY_API_KEY=your_tavily_key_here
